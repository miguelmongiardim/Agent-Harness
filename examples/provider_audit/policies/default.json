{
  "schema_version": "policy.v2",
  "name": "default",
  "description": "Provider audit demo policy with approval-bound recorded provider use.",
  "profile_kind": "default",
  "documented": true,
  "deliberate_selection_required": true,
  "trust_zones": {
    "rules": {
      "mock": "allow",
      "local_process": "allow",
      "local_endpoint": "approval_required",
      "private_network": "approval_required",
      "hosted_provider": "approval_required"
    }
  },
  "provider_input": {
    "rules": {
      "public": "allow",
      "generated": "allow_untrusted",
      "internal": "approval_required",
      "confidential": "deny",
      "restricted": "deny",
      "secret": "deny",
      "credential": "deny",
      "pii": "deny",
      "customer": "deny",
      "unknown": "deny"
    },
    "hard_deny_sensitivities": ["secret", "credential", "pii", "customer"],
    "redact_reclassify": {}
  },
  "approvals": {
    "required_tools": []
  },
  "scanner": {
    "fail_threshold": "high",
    "external_reports": "advisory"
  },
  "template_capabilities": {
    "allowed_capabilities": [],
    "default_action": "deny"
  },
  "migration": {
    "safe_writes": true,
    "preserve_or_tighten": true,
    "allow_loose_rewrites": false
  },
  "allowed_tools": ["read_file", "search_code"],
  "read_roots": ["."],
  "write_roots": ["."],
  "deny_globs": [".git/**", ".venv/**", ".agent-harness/indexes/**"],
  "approval_required_tools": [],
  "allowed_test_commands": [],
  "allow_network": false,
  "max_context_bytes": 20000,
  "security_fail_threshold": "high",
  "sensitivity_rules": [
    {"pattern": "docs/public.md", "classification": "public"}
  ],
  "redaction_patterns": [
    "(?i)(api[_-]?key|token|secret|password)\\s*[:=]\\s*[^\\s]+"
  ]
}
